# Copy to .env and fill in to enable live LLM answers.
# If MINIMAX_API_KEY is unset, Sentinel-Med falls back to deterministic
# response templates so the demo always runs offline.
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-Text-01

# JWT signing secret — change in production
JWT_SECRET=sentinel-med-dev-secret-change-in-prod

# CORS: set to your Next.js Railway URL in production
FRONTEND_URL=http://localhost:3000

# Set in the Railway frontend service to point at the API
# NEXT_PUBLIC_API_URL=https://sentinel-med-api.railway.app
