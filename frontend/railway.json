{
  "$schema": "https://railway.app/railway.schema.json",
  "service": {
    "name": "sentinel-med-ui"
  },
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build",
    "installCommand": "npm install"
  },
  "deploy": {
    "startCommand": "npm start",
    "healthcheckPath": "/",
    "restartPolicy": "on-failure"
  },
  "environment": {
    "NODE_ENV": "production"
  }
}
